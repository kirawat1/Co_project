# Backend/.env.example — คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง

# =====================
# REQUIRED (server จะไม่ start ถ้าขาดค่าเหล่านี้)
# =====================

# Server port
PORT=5000

# MySQL connection string
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/coop_mysql_db?charset=utf8mb4"

# JWT Secret — ต้องเป็น string สุ่มยาว ≥ 64 ตัวอักษร
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_key_here_min_64_chars

# Frontend URL — สำหรับ CORS (ต้องตรงกับ URL ที่ browser เปิด)
# Dev:        http://localhost:5173
# Production: http://YOUR_VM_IP หรือ https://coop.yourdomain.com
FRONTEND_URL=http://localhost:5173

# Node environment
NODE_ENV=production

# =====================
# OPTIONAL — Google OAuth (ถ้าไม่ใส่ นักศึกษาจะ login ด้วย Google ไม่ได้)
# =====================
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# =====================
# OPTIONAL — KKU REG API (ถ้าไม่ใส่ ฟีเจอร์ sync จาก REG API จะถูก disable)
# =====================
KKU_REG_BASE_URL=https://reg2.kku.ac.th/api/v1.2
KKU_REG_CLIENT_ID=
KKU_REG_CLIENT_SECRET=

# Legacy (ไม่ได้ใช้แล้ว — เก็บไว้ backward compat)
KKU_API_TOKEN=
