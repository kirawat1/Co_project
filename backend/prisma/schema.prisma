generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. User & Auth (คงเดิม)
// ==========================================
model User {
  id             Int     @id @default(autoincrement())
  username       String  @unique
  password       String?
  email          String?
  role           Role    @default(student)
  provider       String  @default("credentials")
  kkuAccessToken String? @db.Text

  student   Student?
  teacher   Teacher?
  companies Company[]
  mentors   Mentor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique // เช่น 'EVALUATION_FORMS'
  value     String   @db.Text // เก็บข้อมูลเป็น JSON String
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. Student Data (คงเดิม)
// ==========================================
model Student {
  id        Int    @id @default(autoincrement())
  studentId String @unique

  prefix       Prefix?
  firstName    String
  lastName     String
  firstNameEn  String?
  lastNameEn   String?
  major        String?
  curriculum   String?
  year         String?
  phone        String?
  email        String?
  studyProgram StudyProgram?
  gpa          Float?        @default(0.00)
  coreGpa      Float?        @default(0.00)
  activityUnit Int           @default(0)
  apiSyncedAt  DateTime?
  advisorName  String? // ชื่ออาจารย์ที่ปรึกษา
  jobPosition  String? // ตำแหน่งงานที่สนใจ/สมัคร

  generalAdvisorId  Int?
  coopAdvisorId     Int?
  generalAdvisor    Teacher? @relation("GeneralAdvisor", fields: [generalAdvisorId], references: [id])
  coopAdvisor       Teacher? @relation("CoopAdvisor", fields: [coopAdvisorId], references: [id])

  isPassPrepCourse Boolean @default(false)
  isQualified      Boolean @default(false)

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])

  coop      StudentCoop?
  documents Document[]
  emails    StudentEmail[]
  visits    Visit[]

  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  coopApplicationForm    CoopApplicationForm?
  t003Form               CoopT003Form?
  supervisionAppointment SupervisionAppointment?
}

// ==========================================
// 3. Coop Process (แก้ไขใหม่ให้ตรง Workflow)
// ==========================================
model StudentCoop {
  id Int @id @default(autoincrement())

  studentId Int        @unique
  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // Status Workflow (ปรับตาม Diagram)
  status    CoopStatus @default(APPLYING)

  // --- Step 1-3: อาจารย์ตรวจสอบคุณสมบัติ ---
  // อาจารย์อาจจะ Note เหตุผลที่ไม่ผ่าน (QUALIFICATION_FAILED)
  teacherCheckComment String?   @db.Text
  teacherCheckDate    DateTime?

  // --- Step 4: นักศึกษายื่น CP-T000 (เลือกบริษัท) ---
  companyId String? // ยังเป็น Optional เพราะตอนสมัครครั้งแรกอาจยังไม่เลือก
  company   Company? @relation(fields: [companyId], references: [id])

  jobPosition String? // ตำแหน่งที่สมัคร

  t000Status  DocStatus @default(WAITING)
  t000Comment String?   @db.Text

  // --- Step 5-6: เจ้าหน้าที่ตรวจเอกสาร & ออก "เอกสารยื่นสหกิจ" (ใบแรก) ---
  staffCheckComment String?   @db.Text // เหตุผลที่ให้แก้เอกสาร (EDITS_REQUIRED)
  reqDocNumber      String? // เลขที่หนังสือ "ที่ อว 660301..."
  reqDocDate        DateTime? // วันที่ออกหนังสือ
  reqLetterUrl      String? // ไฟล์ PDF ออกเอกสารยื่นสหกิจ 

  // --- Step 7-9: ยื่นบริษัท & รอหนังสือส่งตัว (ใบสอง) ---
  acceptanceFileUrl String? // ไฟล์ใบตอบรับจากบริษัท (หน้า 13)

  // ข้อมูลสำหรับหนังสือส่งตัว
  actualStartDate DateTime? // วันเริ่มงานจริง
  actualEndDate   DateTime? // วันจบงานจริง

  placeDocNumber String? // เลขที่หนังสือส่งตัว "ที่ อว..."
  placeDocDate   DateTime? // วันที่ออกหนังสือส่งตัว
  placeLetterUrl String? // ไฟล์ PDF ส่งตัว 

  // Mentor (พี่เลี้ยง) อาจจะมาใส่ทีหลังตอนเริ่มฝึกงานแล้ว
  mentorId String?
  mentor   Mentor? @relation(fields: [mentorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ความสัมพันธ์: นักศึกษาสหกิจ 1 คน อยู่ในรอบการรับสมัครสหกิจได้แค่รอบเดียว (ถ้าอยากสมัครรอบใหม่ ต้องลบอันเก่าออกก่อน)
  coopPeriod   CoopPeriod? @relation(fields: [coopPeriodId], references: [id])
  coopPeriodId Int?
}

model CoopPeriod {
  id           Int      @id @default(autoincrement())
  academicYear String // ปีการศึกษา เช่น "2569"
  semester     Int // ภาคการศึกษา เช่น 1, 2, 3
  startDate    DateTime // วันที่เริ่มเปิดรับสมัคร (เช่น 25-เมษา-69)
  endDate      DateTime // วันที่ปิดรับสมัคร (เช่น 25-ตุลา-69)
  isActive     Boolean  @default(false) // สถานะให้เจ้าหน้าที่กด ปิด/เปิด รับสมัครแบบ Manual ได้

  supervisionStartDate DateTime?
  supervisionEndDate   DateTime?
  isSupervisionOpen    Boolean       @default(false)
  // ความสัมพันธ์: 1 รอบการรับสมัคร มีนักศึกษาเข้าโครงการหลายคน
  studentCoops         StudentCoop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicYear, semester]) // ป้องกันเจ้าหน้าที่สร้างปีและเทอมซ้ำกัน
}

model CoopApplicationForm {
  id        Int     @id @default(autoincrement())
  studentId Int     @unique
  student   Student @relation(fields: [studentId], references: [id])

  // --- ข้อมูลที่อยู่ที่ติดต่อได้ ---
  contactAddress String? @db.Text
  contactPhone   String?
  contactEmail   String?

  // --- ข้อมูลบุคคลฉุกเฉิน ---
  emergencyName      String?
  emergencyRelation  String?
  emergencyJob       String?
  emergencyWorkplace String?
  emergencyAddress   String? @db.Text
  emergencyPhone     String?
  emergencyEmail     String?

  // --- ✅ เพิ่ม: ระยะเวลาปฏิบัติงาน (ตามที่ขอ) ---
  startDate DateTime?
  endDate   DateTime?

  // --- ✅ เพิ่ม: จุดมุ่งหมายอาชีพ (3 ข้อ) ---
  careerObjective1 String?
  careerObjective2 String?
  careerObjective3 String?

  updatedAt DateTime @updatedAt
}

// ==========================================
// 4. Admin Configuration (คงเดิม)
// ==========================================
model CoopCriteria {
  id              String   @id @default(uuid())
  major           String   @unique
  minGpa          Float    @default(2.00)
  minCoreGpa      Float    @default(2.00)
  minActivityUnit Int      @default(0)
  requiredCourses  Json
  coreCourses      Json
  prepCourseCodes  Json     @default("[]") // วิชาเตรียมความพร้อม เช่น ["CP002001","SC002001"]
  electiveMinCount Int      @default(1)    // จำนวนวิชาบังคับเลือกขั้นต่ำ
  updatedAt        DateTime @updatedAt
}

// ==========================================
// 5. Supporting Models (ปรับ Company นิดหน่อย)
// ==========================================

model Company {
  id          String  @id @default(uuid())
  name        String
  nameEn      String?
  address     String? @db.Text
  addressNo   String? // เลขที่
  moo         String? // หมู่
  soi         String? // ซอย
  road        String? // ถนน
  subDistrict String? // ตำบล/แขวง
  district    String? // อำเภอ/เขต
  province    String? // จังหวัด
  zipcode     String? // รหัสไปรษณีย์
  fax         String? // โทรสาร
  phone       String?
  email       String?
  website     String?
  pastYears   String?

  // เพิ่มข้อมูลผู้ติดต่อเพื่อนำไป Gen ลง PDF (เรียน คุณ...)
  contactPerson   String?
  contactPosition String?

  mentors      Mentor[]
  studentCoops StudentCoop[]

  createdById Int
  createdBy   User @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mentor {
  id           String        @id @default(uuid())
  firstName    String
  lastName     String
  department   String?
  position     String?
  email        String?
  phone        String?
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  studentCoops StudentCoop[]
  createdById  Int
  createdBy    User          @relation(fields: [createdById], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Teacher {
  id                      Int                      @id @default(autoincrement())
  firstName               String
  lastName                String
  email                   String                   @unique
  phone                   String?
  faculty                 String?
  major                   String?
  userId                  Int                      @unique
  user                    User                     @relation(fields: [userId], references: [id])
  visits                  Visit[]
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  supervisionAppointments SupervisionAppointment[]
  generalAdvisees         Student[]                @relation("GeneralAdvisor")
  coopAdvisees            Student[]                @relation("CoopAdvisor")
}

model Visit {
  id        Int      @id @default(autoincrement())
  date      DateTime
  time      String?
  location  String?
  note      String?
  status    String   @default("scheduled")
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  teacherId Int
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  createdAt DateTime @default(now())
}

model Document {
  id           Int       @id @default(autoincrement())
  studentId    Int
  student      Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name         String
  path         String
  rejectReason String?
  type         String? // เช่น "T000", "PLACEMENT_LETTER", "OTHER"
  status       DocStatus @default(WAITING)
  uploadedAt   DateTime  @default(now())
}

model DocumentRequirement {
  id          Int     @id @default(autoincrement())
  docKey      String  @unique // เช่น "CP-T000", "CP-TRANSCRIPT"
  title       String // เช่น "ใบสมัครงานสหกิจศึกษา (T000)"
  description String? // คำอธิบายเพิ่มเติม (ถ้ามี)
  isRequired  Boolean @default(true) // บังคับอัปโหลดหรือไม่
  isActive    Boolean @default(true) // เปิด/ปิด การใช้งาน

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentEmail {
  id        Int     @id @default(autoincrement())
  email     String
  primary   Boolean @default(false)
  studentId Int
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Announcement {
  id           String    @id @default(uuid())
  title        String
  body         String?   @db.Text
  date         DateTime
  year         String
  linkUrl      String?
  targetMajors Json      @default("[]")
  files        AnnFile[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
}

model AnnFile {
  id             String       @id @default(uuid())
  announcementId String
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  name           String
  mime           String
  path           String
}

model SystemAsset {
  key       String   @id // ตัวระบุ เช่น 'KRUT', 'SIGNATURE', 'PROJECT_DETAILS', 'ACCEPTANCE_FORM'
  label     String // ชื่อแสดงผล เช่น 'ตราครุฑ', 'รายละเอียดโครงการ'
  path      String // path ไฟล์บน server
  mimeType  String? // เก็บว่าเป็น pdf หรือ png
  updatedAt DateTime @updatedAt
}

// ==========================================
// Enums (อัปเดตใหม่ตาม Diagram เป๊ะๆ)
// ==========================================

enum CoopStatus {
  // --- Zone 1: อาจารย์ตรวจสอบ ---
  NOT_SUBMITTED // 0. ยังไม่ยื่นสหกิจ
  APPLYING // 1. นศ. ยื่นสหกิจ (รออาจารย์ตรวจสอบคุณสมบัติ)
  QUALIFICATION_FAILED // 2. ไม่ผ่าน (อาจารย์ปฏิเสธ -> กลับไปแก้คุณสมบัติไม่ได้แล้ว ต้องคุยนอกรอบ)
  APPLICATION_EDITS_REQUIRED // 2. แก้ไขคุณสมบัติ (อาจารย์สั่งแก้ -> นศ. กลับไปแก้ -> ส่งใหม่)
  QUALIFIED // 3. เป็นนักศึกษาสหกิจ (ผ่านเกณฑ์อาจารย์)

  // --- Zone 2: เจ้าหน้าที่ตรวจเอกสารสมัคร (CP-T000) ---
  WAITING_FOR_STAFF_CHECK // 4. นศ. ยื่น KKU CP-T000 (รอเจ้าหน้าที่ตรวจ)
  EDITS_REQUIRED // 5. แก้เอกสาร (เจ้าหน้าที่สั่งแก้ -> นศ. กลับไปแก้ -> ส่งใหม่)
  DOCS_APPROVED // 6. เอกสารผ่าน (เจ้าหน้าที่อนุมัติเอกสาร)
  REQ_LETTER_ISSUED // 6. ออกเอกสารยื่นสหกิจ (ผ่าน) -> นศ. โหลดไปยื่นบริษัท

  // --- Zone 3: ตอบรับ & ส่งตัว ---
  WAITING_FOR_PLACEMENT_LETTER // 7. ยื่นใบตอบรับจากบริษัท 
  WAITING_FOR_STAFF_CHECK_LETTER // 7. รอเจ้าหน้าที่ตรวจหนังสือส่งตัว
  ACCEPTANCE_CHECKED // 7. หนังสือส่งตัวผ่าน (รอเจ้าหน้าที่อนุมัติหนังสือส่งตัว)
  PLACEMENT_LETTER_ISSUED // 8. ออกหนังสือรับรองการฝึกงานออกให้แล้ว

  // --- Zone 4: ปฏิบัติงาน ---
  INTERNSHIP_STARTED // 9. เริ่มออกฝึกสหกิจ

  T002_SUBMITTED
  T002_EDITS_REQUIRED
  T003_SUBMITTED
  T003_EDITS_REQUIRED
  T003_APPROVED
}

model CoopT003Form {
  id        Int     @id @default(autoincrement())
  studentId Int     @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  reportTitleTh    String? @db.Text
  reportTitleEn    String? @db.Text
  objectives       String? @db.Text
  expectedOutcomes String? @db.Text
  significance     String? @db.Text
  references       String? @db.Text
  methodology      String? @db.Text
  scope            String? @db.Text
  otherSuggestions String? @db.Text

  // เก็บแผนงาน 16 สัปดาห์เป็น JSON Array ไปเลย จะได้ยืดหยุ่น
  workPlan Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  student
  teacher
  staff
}

enum Prefix {
  MR
  MS
}

enum StudyProgram {
  normal
  special
}

enum DocStatus {
  WAITING
  PENDING
  APPROVED
  REJECTED
  EDITS_REQUIRED
}

enum SupervisionStatus {
  PENDING_TEACHER // 1. นศ. เสนอวันแล้ว รออาจารย์เลือก
  TEACHER_REJECTED // 2. อาจารย์ไม่ว่าง ให้ นศ. เลือกใหม่
  DATE_CONFIRMED // 3. อาจารย์เลือกวันแล้ว รอ จนท. ออกหนังสือ
  LETTER_UPLOADED // 4. จนท. อัปโหลดหนังสือที่คณบดีเซ็นแล้ว
  COMPLETED // 5. นิเทศเสร็จสิ้น
}

enum SupervisionType {
  ONLINE
  ONSITE
}

model SupervisionAppointment {
  id            Int     @id @default(autoincrement())
  studentId     Int     @unique // 1 นศ. ต่อ 1 การนัดหมาย
  teacherId     Int // อาจารย์ผู้นิเทศ
  coTeacherName String? @db.Text
  // นศ. เสนอมาเป็น Array ของวันที่และเวลา (เก็บเป็น JSON string เช่น ["2026-04-10T10:00", "2026-04-11T13:00"])
  proposedDates String  @db.Text

  supervisionType SupervisionType // ออนไลน์ หรือ ออนไซต์

  // อาจารย์ตอบกลับ
  confirmedDate DateTime? // วันที่อาจารย์เลือก (ถ้ามี)
  rejectReason  String?   @db.Text // เหตุผลที่ให้ นศ. เลือกใหม่

  status SupervisionStatus @default(PENDING_TEACHER)

  // ไฟล์หนังสือขอความอนุเคราะห์นิเทศ (ที่คณบดีเซ็นแล้ว)
  officialLetterPath String?
  onlineLink         String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id])
}
