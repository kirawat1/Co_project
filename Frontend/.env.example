# Frontend/.env.example — คัดลอกเป็น .env แล้วใส่ค่าจริง

# =====================
# REQUIRED — Google OAuth Client ID
# =====================
# ดูจาก Google Cloud Console → APIs & Services → Credentials
# ต้องเพิ่ม authorized origins ให้ตรงกับ URL จริงก่อน deploy
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
